{
  "name": "condoa-back",
  "version": "1.0.0",
  "main": "dist/server.js",
  "packageManager": "yarn@4.12.0",
  "license": "MIT",
  "dependencies": {
    "@eslint/migrate-config": "^2.0.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.6",
    "multer": "^2.1.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "deploy:mvp": "yarn build && yarn migration:run && yarn seed:admin",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js -d src/shared/database/data-source.ts",
    "migration:generate": "yarn typeorm migration:generate src/shared/database/migrations/InitialMigration",
    "migration:run": "yarn typeorm migration:run",
    "migration:revert": "yarn typeorm migration:revert",
    "seed:admin": "node --require ts-node/register ./src/shared/database/seeds/admin.seed.ts"
  }
}
